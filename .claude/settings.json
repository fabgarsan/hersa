{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "!Read(./.env.example)",
      "Read(./backend/.env)",
      "Read(./backend/.env.*)",
      "!Read(./backend/.env.example)",
      "Read(./frontend/.env)",
      "Read(./frontend/.env.*)",
      "!Read(./frontend/.env.example)",
      "Read(./**/secrets/**)",
      "Read(./**/credentials/**)",
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)"
    ],
    "allow": [
      "Bash(chmod +x *)",
      "Bash(claude mcp *)",
      "Bash(docker compose *)",
      "Bash(gh api *)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(git *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(find . *)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(pip index *)",
      "Bash(pipenv install *)",
      "Bash(pipenv run *)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.claude.ai)",
      "WebFetch(domain:eventosintertogas.com)",
      "WebFetch(domain:mui.com)",
      "WebFetch(domain:v6.mui.com)",
      "WebSearch",
      "mcp__linear-server__get_issue",
      "mcp__linear-server__get_project",
      "mcp__linear-server__get_team",
      "mcp__linear-server__list_cycles",
      "mcp__linear-server__list_issue_labels",
      "mcp__linear-server__list_issue_statuses",
      "mcp__linear-server__list_issues",
      "mcp__linear-server__list_milestones",
      "mcp__linear-server__list_projects",
      "mcp__linear-server__list_teams",
      "mcp__linear-server__list_users",
      "mcp__linear-server__save_issue",
      "mcp__linear-server__save_comment"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/deny-secret-commits.sh"
          }
        ]
      }
    ]
  }
}
